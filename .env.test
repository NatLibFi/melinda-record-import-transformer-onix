# This environment is loaded only for purposes of testing value transfer from environmental variable to runtime
# It is used only by src/index.test.js

# All filtering, transformation, and validation code and associated tests are not dependent on these values
# Instead the values are defined in the metadata.json of the test file if they are required by the test

# Runtime
NODE_ENV=test
LOG_LEVEL=silent

# Melinda Record Import defaults for automated tests
ABORT_ON_INVALID_RECORDS=false
NEXT_QUEUE_STATUS=TRANSFORMED
POLLTIME=3000
PROFILE_IDS='["foo-profile"]'
READ_FROM=blobContent

AMQP_URL=amqp://127.0.0.1:5672/
MONGO_URI=mongodb://127.0.0.1/db

# Filter configuration
APPLY_FILTERS='["recordTypeFilter", "subjectFilter"]'
ALLOW_RECORD_TYPES='["electronic"]'
DENY_SUBJECT_CODES='["00"]'

# Transformer defaults for automated tests (note: may be overridden by individual tests)
IS_LEGAL_DEPOSIT=true

SOURCE=foo-source
PSEUDONYM=foo-pseudonym
RELATED_WORK_REFERENCE_NAME=foo-relatedWorkReferenceName
ISIL_IDENTIFIER=foo-isilIdentifier
NOTIFICATION_NAME=foo-notificationName
SYSTEM_IDENTIFIER=foo-systemIdentifier
F984_DIRECTIVES='["FOO-DIRECTIVE"]'
LANGUAGE_SANITY_CHECK=false
PREVENT_UNIFORM_TITLE_GENERATION=false
